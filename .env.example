PORT=4000
NODE_ENV=development

# Supabase Configurations
SUPABASE_URL=your_supabase_url
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# JWT Secret for token signing (Optional fallback)
JWT_SECRET=your_jwt_secret_change_in_production

# CORS
ALLOWED_ORIGINS=*

# Redis (For BullMQ queue management)
REDIS_URL=redis://127.0.0.1:6379

# Discord Bot / Bridge (Selfbot account token)
DISCORD_TOKEN=your_discord_selfbot_account_token

# Discord Channel IDs for different game versions and user plans
DISCORD_CHANNEL_ID_SV=your_discord_channel_id_for_scarlet_violet
DISCORD_CHANNEL_ID_ZA_FREE=your_discord_channel_id_for_za_free_plan
DISCORD_CHANNEL_ID_ZA_PREMIUM=your_discord_channel_id_for_za_premium_plan
DISCORD_CHANNEL_ID_ZA=your_fallback_za_channel_id

